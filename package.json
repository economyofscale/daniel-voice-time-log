{
  "name": "voice-time-log",
  "private": true,
  "version": "0.1.0",
  "description": "Log work time by speaking - local voice time tracker",
  "author": "Daniel Fixemer",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron:dev": "concurrently -k \"npm run dev\" \"wait-on http://localhost:5173 && electron .\"",
    "electron:build": "vite build && electron-builder --win"
  },
  "build": {
    "appId": "com.danielf.voicetimelog",
    "productName": "Voice Time Log",
    "electronDist": "node_modules/electron/dist",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.112.2",
    "@xenova/transformers": "^2.17.2",
    "idb": "^8.0.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^10.0.3",
    "electron": "^43.1.1",
    "electron-builder": "^26.15.3",
    "vite": "^6.0.7",
    "wait-on": "^9.0.10"
  },
  "allowScripts": {
    "esbuild@0.25.12": true,
    "electron-winstaller@5.4.0": true,
    "electron@43.1.1": true
  }
}
